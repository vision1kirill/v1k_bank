# ============================================================
# ИНВЕСТИЦИОННЫЙ БОТ — ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
# Скопируй этот файл в .env и заполни свои значения
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
# Получи у @BotFather → /newbot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── T-Bank (Tinkoff) Invest API ──────────────────────────────
# 1. Открой приложение Т-Инвестиции
# 2. Настройки → Прочее → Подключить API
# 3. Создай токен с полными правами (для торговли)
TINKOFF_TOKEN=your_tinkoff_invest_token_here

# ID торгового счёта (оставь пустым — бот возьмёт первый доступный)
TINKOFF_ACCOUNT_ID=

# ── Безопасность ─────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО: твой Telegram User ID (узнай у @userinfobot)
# Через запятую если несколько пользователей
ALLOWED_USER_IDS=123456789

# ── Режим торговли ───────────────────────────────────────────
# true  = SANDBOX (бумажная торговля, безопасно для тестов)
# false = РЕАЛЬНАЯ торговля (осторожно! реальные деньги)
USE_SANDBOX=true

# ── База данных ──────────────────────────────────────────────
# Railway автоматически задаёт DATABASE_URL для PostgreSQL
# Для локальной разработки оставь пустым (будет SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Расписание (UTC время) ───────────────────────────────────
# Ежедневный анализ: 07:00 UTC = 10:00 МСК
DAILY_ANALYSIS_HOUR_UTC=7
DAILY_ANALYSIS_MINUTE_UTC=0

# Еженедельный отчёт: понедельник 08:00 UTC = 11:00 МСК
WEEKLY_REPORT_DAY=0
WEEKLY_REPORT_HOUR_UTC=8

# Проверка Grid ордеров каждые N секунд
GRID_CHECK_INTERVAL_SEC=300

# ── Логирование ──────────────────────────────────────────────
LOG_LEVEL=INFO
